{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/JacekDziurdzikowski/laravel-blade-sortable"
        }
    ],
    "require": {
        "php": "^8.2",
        "agatanga/flags": "^1.2",
        "calebporzio/sushi": "^2.5",
        "easylo/freeswitcheventsocketlistener": "^1.0",
        "faisalman/simple-excel-php": "0.3.*",
        "guzzlehttp/guzzle": "^7.10",
        "jacekdziurdzikowski/laravel-blade-sortable": "dev-master",
        "laravel/breeze": "^1.29",
        "laravel/framework": "^10.50",
        "laravel/reverb": "^1.7.1",
        "laravel/tinker": "^2.11",
        "livewire/livewire": "^2.12",
        "maatwebsite/excel": "^3.1.67",
        "mckenziearts/laravel-notify": "^2.7",
        "petercoles/multilingual-country-list": "^1.2",
        "simplesoftwareio/simple-qrcode": "^4.2",
        "stomp-php/stomp-php": "^5.1.4"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.15",
        "barryvdh/laravel-ide-helper": "^2.15",
        "laravel/dusk": "^8.3.5",
        "mockery/mockery": "^1.6",
        "pestphp/pest": "^2.36",
        "pestphp/pest-plugin-laravel": "^2.4",
        "phpunit/phpunit": "^10.5.62"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/helpers.php",
            "app/Helpers/worksWithDates.php",
            "app/Helpers/worksWithTranslations.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "cweagans/composer-patches": false
        },
        "platform": {
            "php": "8.2.25"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
